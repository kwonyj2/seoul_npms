# ─────────────────────────────────────────
# NPMS 환경변수 템플릿
# 운용서버에서 이 파일을 .env로 복사 후 값을 채우세요
# cp .env.example .env
# ─────────────────────────────────────────

# Django 보안
SECRET_KEY=your-secret-key-here-change-this
DEBUG=False
ALLOWED_HOSTS=your.server.ip,localhost
CSRF_TRUSTED_ORIGINS=http://your.server.ip,http://your.server.ip:8081
FORCE_SCRIPT_NAME=/npms

# PostgreSQL
DB_HOST=db
DB_NAME=npms_db
DB_USER=django
DB_PASSWORD=change-this-password
DB_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Celery Flower 모니터링
FLOWER_USER=admin
FLOWER_PASSWORD=change-this-password
FLOWER_URL=/npms/flower/

# NAS 경로 (운용서버 마운트 경로)
NAS_ROOT=/mnt/lvm-cache/nas
MEDIA_ROOT=/mnt/lvm-cache/nas/media/npms

# 외부 API
VWORLD_API_KEY=
AI_SERVER_URL=http://npms_ai:8001
ANTHROPIC_API_KEY=

# 슈퍼관리자 초기 계정 (최초 1회만 사용)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-this-password

# 이메일 (SMS 알림용)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# SMS (SOLAPI)
SMS_PROVIDER=solapi
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_NUMBER=
SMS_ENABLED=False

# DB 백업
DB_BACKUP_DIR=/home/user/network_pms/backups
DB_BACKUP_KEEP_DAYS=30

# 사이트 URL
SITE_URL=http://your.server.ip/npms
